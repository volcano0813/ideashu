# Cover image (optional). Leave empty to skip AI cover generation.
SILICONFLOW_API_KEY=

# Sync server port (default 3001; must match frontend useIdeashuSync defaults)
SYNC_PORT=3001

# Feishu webhook (optional; leave empty to disable push)
FEISHU_WEBHOOK_URL=

# OpenClaw workspace path (Windows: backslashes OK)
OPENCLAW_WORKSPACE=C:\Users\YOUR_USERNAME\.openclaw\workspace

# Optional: absolute path for sync SQLite/JSON data (default: sync/data.json under repo)
# IDEASHU_SYNC_DATA_FILE=